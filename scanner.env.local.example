# =============================================================================
# AI Scanner — local environment config
# =============================================================================
# Copy this file:  cp scanner.env.local.example scanner.env.local
# Then fill in:    GITHUB_TOKEN (required)
#
# scanner.env.local is git-ignored — your token will never be committed.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub personal access token
# Used to authenticate with GitHub Models (GPT-4o) — no OpenAI account needed.
# Create at: https://github.com/settings/tokens?type=beta
# Minimum permission: "Models" → Read  (or any valid GitHub token works)
GITHUB_TOKEN=ghp_your_token_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Docker image to use for local scans.
# Default (local build):  ai-scanner:local
# GHCR (pre-built):       ghcr.io/YOUR_GITHUB_USERNAME/ai-scanner:latest
SCANNER_IMAGE=ai-scanner:local

# Override the LLM model (default: gpt-4o)
# Available models: https://github.com/marketplace/models
# SCANNER_MODEL=gpt-4o

# Override the fallback model used when rate limited (default: gpt-4o-mini)
# SCANNER_FALLBACK_MODEL=gpt-4o-mini
